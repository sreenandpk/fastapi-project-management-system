  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// ALWAYS reset Authorization to avoid duplicates",
          "pm.request.headers.remove('Authorization');",
          "let token = pm.environment.get('token');",
          "if (token) {",
          "  pm.request.headers.add({",
          "    key: 'Authorization',",
          "    value: 'Bearer ' + token",
          "  });",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
